<Window x:Class="WPF_Template.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Template"
        mc:Ignorable="d"
         Title="MyTemplate" 
        Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="1"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid x:Name="HeaderPanel" 
      Grid.Row="0" 
      Background="#2D2D30" 
      MouseLeftButtonDown="HeaderPanel_MouseLeftButtonDown">
            
            <TextBlock Text="name" 
               Foreground="White" 
               VerticalAlignment="Center" 
               Margin="15,0,0,0" 
               FontSize="12"/>

            <StackPanel Orientation="Horizontal" 
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch">

                <Button Width="45" 
                Content="&#xE921;" 
                FontFamily="Segoe MDL2 Assets" 
                FontSize="10"
                Foreground="White"
                Background="Transparent"
                BorderThickness="0"
                WindowChrome.IsHitTestVisibleInChrome="True"
                Click="MinimizeButton_Click"
                Style="{StaticResource WindowControlButtonStyle}"/>

                <Button x:Name="MaximizeBtn"
                Width="45" 
                Content="&#xE922;" 
                FontFamily="Segoe MDL2 Assets" 
                FontSize="10"
                Foreground="White"
                Background="Transparent"
                BorderThickness="0"
                WindowChrome.IsHitTestVisibleInChrome="True"
                Click="MaximizeButton_Click"
                Style="{StaticResource WindowControlButtonStyle}"/>

                <Button Width="45" 
                Content="&#xE8BB;" 
                FontFamily="Segoe MDL2 Assets" 
                FontSize="10"
                Foreground="White"
                Background="Transparent"
                BorderThickness="0"
                WindowChrome.IsHitTestVisibleInChrome="True"
                Click="CloseButton_Click"
                Style="{StaticResource CloseControlButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="ContentGrid" Grid.Row="1" Background="green">
            <TabControl Grid.Row="1" 
                    Background="Transparent" 
                    BorderThickness="0"
                    Margin="0">
                <TabItem Header="Main" Padding="10,5">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Background="#252526">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="text" 
                                   Foreground="White" 
                                   FontSize="20" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,1000"/>
                                <TextBlock Text="Its template" 
                                   Foreground="Gray" 
                                   HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
        <Grid x:Name="FooterPanel" Grid.Row="2" Background="red"></Grid>
    </Grid>
</Window>
